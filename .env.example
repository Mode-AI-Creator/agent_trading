# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in your own keys:   cp .env.example .env
# .env is git-ignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development            # development | production
APP_PORT=8000
LOG_LEVEL=INFO

# ── DeepSeek AI (required — the trading agent runs on this) ──────────────────
DEEPSEEK_API_KEY=             # get one at https://platform.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ── OKX Exchange (required for LIVE trading; market data works without keys) ─
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_REFERRAL_CODE=            # optional affiliate code
OKX_BASE_URL=https://www.okx.com

# ── Symbols & Scheduler ──────────────────────────────────────────────────────
TARGET_SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,XRP-USDT
ENABLE_SCHEDULER=true
SCHEDULER_TIMEZONE=Asia/Shanghai

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/kol.db

# ── Auto Trading ─────────────────────────────────────────────────────────────
TRADING_ENABLED=false                  # master switch (needed for paper or live)
TRADING_PAPER_MODE=true                # true=paper (no orders) / false=live orders
TRADING_AGENT_MODEL=deepseek-chat      # DeepSeek model the agent uses
TRADING_MAX_LEVERAGE=5                 # max leverage the agent may pick (1–N)
TRADING_POSITION_SIZE_PCT=10           # fallback size; agent decides 1–20% per trade
TRADING_DAILY_LOSS_LIMIT_USDT=100      # halt trading once daily loss exceeds this
TRADING_MAX_OPEN_POSITIONS=10          # max simultaneous open positions
PAPER_INITIAL_BALANCE_USDT=10000.0     # starting equity for the paper curve
